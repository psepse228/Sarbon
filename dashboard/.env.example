# --- Supabase (server-only; never prefix with NEXT_PUBLIC_) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram bot, used to validate initData HMAC server-side ---
TELEGRAM_BOT_TOKEN=

# --- Telegram-owner -> tenant_id mapping (PILOT STOPGAP, see dashboard/README.md) ---
# JSON object: { "<telegram_user_id>": "<tenant_id>" }
# Today there's exactly one tenant/owner:
# TELEGRAM_OWNER_TENANT_MAP={"111111111":"005ece7a-2af4-4f22-84f7-25d5e743af9e"}
TELEGRAM_OWNER_TENANT_MAP=

# --- Local dev only: lets you exercise the dashboard outside the Telegram webview. ---
# Never set this in a deployed environment. See src/lib/telegram/auth.ts.
DEV_BYPASS_INIT_DATA=
